{
  "expo": {
    "name": "Zod",
    "slug": "zod",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "zod",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.zod.ai",
      "buildNumber": "2",
      "infoPlist": {
        "CFBundleDevelopmentRegion": "en",
        "CFBundleLocalizations": [
          "en"
        ],
        "CFBundleAllowMixedLocalizations": false,
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "Allow Zod to use your microphone for voice calls."
      }
    },
    "android": {
      "package": "com.zod.ai",
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Zod to use your camera for face verification.",
          "microphonePermission": false
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      "expo-localization",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Zod to record your voice prompts."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Zod to show you relevant matches nearby.",
          "locationWhenInUsePermission": "Allow Zod to show you relevant matches nearby."
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Zod to use Face ID to securely sign you in."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "47479a1e-a314-455f-ae89-56cb2234d873"
      },
      "APP_API_KEY": "33de4e446cdbe7697036c871477f3c54bef1a4832f4a4b4ff6bb2d5475f65207"
    },
    "owner": "abdulkum"
  }
}
